# x402-wallet-mcp Environment Variables

# ── Privy Server Wallet (required) ──
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_APP_SECRET=your-privy-app-secret

# ── Spending Limits ──
# X402_PER_CALL_MAX=5.00    # Max USDC per single API call
# X402_DAILY_CAP=50.00      # Max USDC per day

# ── Network ──
# X402_RPC_URL=https://mainnet.base.org  # Custom Base RPC endpoint

# ── Coinbase Onramp (optional, enables "Buy USDC with debit card") ──
# CDP_API_KEY_ID=organizations/{org_id}/apiKeys/{key_id}
# CDP_API_KEY_SECRET=base64-encoded-ed25519-key
